# =============================================================================
# MedAgent Environment Variables
# Copy this file to .env.local and fill in the values
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Providers
# -----------------------------------------------------------------------------

# OpenAI (optional — deterministic fallback when missing)
OPENAI_API_KEY=

# Ollama (local LLM for iMessage NLP parsing)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=
IMESSAGE_OLLAMA_PARSE_ENABLED=true

# -----------------------------------------------------------------------------
# Solana (AI agent wallet — signs all on-chain transactions)
# -----------------------------------------------------------------------------

# The agent's private key as a JSON array of bytes (from solana-keygen new)
# Run: solana-keygen new && cat ~/.config/solana/id.json
SOLANA_PRIVATE_KEY=

# Or provide a path to the keypair file instead
# SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# Network: devnet (free), testnet, or mainnet-beta
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com

# Deployed medagent_audit program ID (overrides IDL file if set)
SOLANA_PROGRAM_ID=dNiqJwpDnNDDqbJ6R8eQ5UwkXVTd6B2dKJ8M1drmEUR

# Anchor wallet path (used by Anchor CLI, not the app)
# SOLANA_WALLET=~/.config/solana/id.json

# Force local-only audit (skip on-chain writes): set to "1" or "true"
# MEDAGENT_FORCE_LOCAL_AUDIT=

# Cost estimation overrides
# MEDAGENT_SOL_USD=150
# MEDAGENT_SOLANA_WRITE_COST_USD=0.001

# -----------------------------------------------------------------------------
# Auth & Encryption
# -----------------------------------------------------------------------------

# JWT signing secret for session tokens
JWT_SECRET=medagent-dev-secret

# AES-256-GCM encryption pepper for patient data at rest
ENCRYPTION_PEPPER=medagent-dev-pepper

# Doctor verification session secret
DOCTOR_SESSION_SECRET=medagent-doctor-session-secret

# Patient login session secret
PATIENT_SESSION_SECRET=medagent-patient-session-secret

# -----------------------------------------------------------------------------
# Email (Gmail SMTP via App Password)
# -----------------------------------------------------------------------------

# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Generate a password for "Mail" and paste the 16-char code below
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
APPOINTMENT_SHARE_EMAIL_TO=gulsameer1000@gmail.com

# -----------------------------------------------------------------------------
# iMessage Bridge (macOS only)
# -----------------------------------------------------------------------------

# Bridge mode: macos-local (real iMessage) or mock (dev/testing)
IMESSAGE_BRIDGE_KIND=mock

# Activation keyword patients text to start onboarding
IMESSAGE_ACTIVATION_KEYWORD="hey baymax!"

# Debug logging for iMessage NLP
IMESSAGE_DEBUG=true

# Disable AppleScript UI automation (set true on CI or non-macOS)
IMESSAGE_DISABLE_UI_AUTOMATION=true

# Webhook secret for iMessage poller → API authentication
IMESSAGE_WEBHOOK_SECRET=

# Optional: override Messages sqlite path
# IMESSAGE_CHAT_DB_PATH=/Users/<you>/Library/Messages/chat.db

# Optional: poller tuning
# IMESSAGE_POLLER_INTERVAL_MS=2000
# IMESSAGE_POLLER_BATCH_SIZE=25
# IMESSAGE_POLLER_BOOTSTRAP=latest
# IMESSAGE_POLLER_SKIP_HISTORY_ON_START=true
# IMESSAGE_POLLER_ONLY_IMESSAGE_SERVICE=true
# IMESSAGE_POLLER_ALLOWED_HANDLES=+353871000001,+447700900201
# IMESSAGE_POLLER_STATE_PATH=/absolute/path/to/imessage-poller-state.json

# Ollama timeout for NLP parsing (ms)
# IMESSAGE_OLLAMA_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# RAG / Retrieval (optional tuning)
# -----------------------------------------------------------------------------

# Local embedding model override
# MEDAGENT_LOCAL_EMBED_MODEL=nomic-embed-text
# MEDAGENT_LOCAL_EMBED_DIMS=768

# Fusion method for hybrid retrieval: rrf (default) or weighted
# MEDAGENT_FUSION_METHOD=rrf

# Enable retrieval plan optimizer
# MEDAGENT_ENABLE_PLAN_OPTIMIZER=true

# Retrieval regression baseline path
# MEDAGENT_RETRIEVAL_REGRESSION_BASELINE=

# Bakeoff candidates JSON path
# MEDAGENT_BAKEOFF_CANDIDATES=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# `npm run dev:tunnel` or `npm run imessage:live:tunnel` updates these to the active ngrok URL.
APP_BASE_URL=http://localhost:3000
NGROK_PUBLIC_URL=

# Public phone number for landing-page Text/iMessage CTAs (must be NEXT_PUBLIC_ to expose to client)
NEXT_PUBLIC_MEDAGENT_PHONE=+447387381555
