# OpenAI (optional — deterministic fallback when missing)
OPENAI_API_KEY=
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
IMESSAGE_OLLAMA_PARSE_ENABLED=true

# Solana
SOLANA_PRIVATE_KEY=
SOLANA_CLUSTER=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET=

# Auth
JWT_SECRET=medagent-dev-secret
ENCRYPTION_PEPPER=medagent-dev-pepper

# iMessage Bridge
IMESSAGE_BRIDGE_KIND=macos-local
IMESSAGE_ACTIVATION_KEYWORD="hey baymax!"
IMESSAGE_DEBUG=true
IMESSAGE_DISABLE_UI_AUTOMATION=false
# Onboarding is persisted per handle in imessage_users (new -> awaiting_* -> onboarded)
# Optional: override Messages sqlite path if needed
# IMESSAGE_CHAT_DB_PATH=/Users/<you>/Library/Messages/chat.db
# Optional: poller tuning
# IMESSAGE_POLLER_INTERVAL_MS=2000
# IMESSAGE_POLLER_BATCH_SIZE=25
# Optional: latest (default) skips historical replay on first run; backfill replays old rows
# IMESSAGE_POLLER_BOOTSTRAP=latest
# Optional: when true (default), always start polling from "now" each launch (no history replay)
# IMESSAGE_POLLER_SKIP_HISTORY_ON_START=true
# Optional: enforce iMessage-only senders (default true)
# IMESSAGE_POLLER_ONLY_IMESSAGE_SERVICE=true
# Optional: comma-separated sender handles. Default is mapped demo handles from lib/imessage/handles.ts
# IMESSAGE_POLLER_ALLOWED_HANDLES=+353871000001,+447700900201,+353861000099,+447700900401,+447700900402,+447700900403
# IMESSAGE_POLLER_STATE_PATH=/absolute/path/to/imessage-poller-state.json
IMESSAGE_WEBHOOK_SECRET=

# App
APP_BASE_URL=http://localhost:3000
